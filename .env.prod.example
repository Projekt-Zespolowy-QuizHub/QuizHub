# Public entrypoint for the app. For now deploying without a domain, use the server IPv4.
PUBLIC_ORIGIN=http://165.245.212.111

# Django / backend
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=165.245.212.111,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://165.245.212.111
CSRF_TRUSTED_ORIGINS=http://165.245.212.111
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
GEMINI_API_KEY=

# PostgreSQL
DB_NAME=quizarena
DB_USER=quizarena
DB_PASSWORD=replace-with-a-strong-db-password

# Frontend / Next.js
# Internal URL used by Next.js server-side rewrites and SSR.
BACKEND_INTERNAL_URL=http://backend:8000

# Public origin exposed to the browser. API calls from the client use /api through Nginx.
NEXT_PUBLIC_API_URL=http://165.245.212.111
NEXT_PUBLIC_WS_URL=ws://165.245.212.111
NEXT_PUBLIC_WS_HOST=165.245.212.111
