# Public entrypoint for the app.
PUBLIC_ORIGIN=https://quizhub.tech

# Django / backend
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=quizhub.tech,www.quizhub.tech,165.245.212.111,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://quizhub.tech,https://www.quizhub.tech
CSRF_TRUSTED_ORIGINS=https://quizhub.tech,https://www.quizhub.tech
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True
GEMINI_API_KEY=

# PostgreSQL
DB_NAME=quizarena
DB_USER=quizarena
DB_PASSWORD=replace-with-a-strong-db-password

# Frontend / Next.js
# Internal URL used by Next.js server-side rewrites and SSR.
BACKEND_INTERNAL_URL=http://backend:8000

# Public origin exposed to the browser. API calls from the client use /api through Nginx.
NEXT_PUBLIC_API_URL=https://quizhub.tech
NEXT_PUBLIC_WS_URL=wss://quizhub.tech
NEXT_PUBLIC_WS_HOST=quizhub.tech
