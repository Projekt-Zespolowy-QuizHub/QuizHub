# ============================================================
# QuizArena — przykładowe zmienne środowiskowe
# Skopiuj ten plik jako .env i uzupełnij wartości.
# NIGDY nie commituj pliku .env z prawdziwymi kluczami.
# ============================================================

# --- Django ---

# Tajny klucz kryptograficzny Django (wymagany w produkcji).
# Wygeneruj własny: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-change-in-production

# Tryb debugowania. W produkcji ustaw na False.
DEBUG=True

# Lista dozwolonych hostów oddzielona przecinkami.
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Baza danych ---

# Silnik bazy danych: "sqlite3" (domyślnie, bez konfiguracji) lub "postgresql".
DB_ENGINE=sqlite3

# Używane tylko gdy DB_ENGINE=postgresql.
# Dane połączenia są na razie zahardkodowane w settings.py — zmień je tam lub rozszerz konfigurację.
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=quizarena
# DB_USER=postgres
# DB_PASSWORD=postgres

# --- Redis (WebSocket / Django Channels) ---

# URL do serwera Redis używany jako warstwa kanałów (channel layer).
# Jeśli pusta, używana jest warstwa InMemory (tylko do lokalnego developmentu).
REDIS_URL=redis://localhost:6379

# --- Google Gemini API (generowanie pytań quizowych przez AI) ---

# Klucz API do usługi Google Gemini.
# Pobierz na: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --- Frontend (informacyjnie, używane przez Next.js, nie przez Django) ---

# URL backendu widoczny z przeglądarki.
# NEXT_PUBLIC_API_URL=http://localhost:8000

# URL WebSocket widoczny z przeglądarki.
# NEXT_PUBLIC_WS_URL=ws://localhost:8000
